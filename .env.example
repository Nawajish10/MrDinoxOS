# === CLIENT-SIDE (NEXT_PUBLIC_ prefix — safe for browser) ===
# Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anonymous/public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Default restaurant UUID
NEXT_PUBLIC_RESTAURANT_ID=

# Deployed app URL (for QR codes, e.g., https://your-domain.vercel.app)
NEXT_PUBLIC_APP_URL=

# Payment webhook endpoint (Optional: falls back to n8n demo webhook if not provided)
NEXT_PUBLIC_PAYMENT_WEBHOOK_URL=

# === SERVER-SIDE (never exposed to client) ===
# Supabase service role key (Required for secure backend operations)
SUPABASE_SERVICE_ROLE_KEY=

# Admin dashboard passcode (e.g., 123456)
ADMIN_PASSCODE=

# Admin login email
ADMIN_EMAIL=

# Admin login password
ADMIN_PASSWORD=
